<!DOCTYPE html><html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Admin — LuxAuto</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🚗</text></svg>">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--primary:#c0392b;--primary-dark:#a93226;--gold:#d4a843;--dark:#0a0a0f;--dark2:#12121a;--dark3:#1e1e30;--text:#f0f0f0;--text-muted:#9999b0;--success:#27ae60;--info:#3498db;--danger:#e74c3c;--card-bg:rgba(30,30,48,0.85);--card-border:rgba(212,168,67,0.15);--radius:16px;--radius-sm:8px;--font-display:'Playfair Display',serif}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
body{font-family:Inter,sans-serif;background:var(--dark);color:var(--text);display:flex}
.sidebar{width:240px;background:var(--dark2);border-right:1px solid var(--card-border);padding:20px 0;height:100vh;position:sticky;top:0;flex-shrink:0;overflow-y:auto}
.sidebar .logo{font-family:var(--font-display);font-size:20px;padding:0 20px 20px;border-bottom:1px solid var(--card-border);margin-bottom:12px}
.sidebar .logo span{color:var(--gold)}
.nav-item{padding:10px 20px;font-size:13px;color:var(--text-muted);cursor:pointer;display:flex;align-items:center;gap:10px}
.nav-item:hover{background:rgba(255,255,255,0.03);color:var(--text)}
.nav-item.active{background:rgba(212,168,67,0.1);color:var(--gold)}
.nav-item .count{margin-left:auto;background:var(--primary);color:#fff;font-size:10px;padding:2px 8px;border-radius:10px}
.main{flex:1;padding:28px 32px;max-height:100vh;overflow-y:auto}
.main-header h1{font-family:var(--font-display);font-size:28px}.main-header h1 span{color:var(--gold)}
.tab{display:none}.tab.active{display:block}
.card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:24px;margin-bottom:20px}
.card h3{font-size:16px;margin-bottom:14px}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin:20px 0}
.stat-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:20px;text-align:center}
.stat-card .n{font-family:var(--font-display);font-size:32px;color:var(--gold)}
.stat-card .l{font-size:11px;color:var(--text-muted);text-transform:uppercase}
.form-row{margin-bottom:12px}
.form-row label{display:block;font-size:11px;color:var(--text-muted);margin-bottom:3px;text-transform:uppercase}
.form-row input,.form-row textarea,.form-row select{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);padding:10px 14px;border-radius:6px;color:var(--text);font-size:13px}
.form-row input:focus{border-color:var(--gold)}
.btn{padding:10px 22px;border-radius:6px;font-size:13px;font-weight:600;display:inline-flex;align-items:center;gap:6px;cursor:pointer;border:none}
.btn-gold{background:linear-gradient(135deg,var(--gold),#e6c75a);color:#000}
.btn-primary{background:var(--primary);color:#fff}
.btn-danger{background:var(--danger);color:#fff}
.btn-success{background:var(--success);color:#fff}
.btn-info{background:var(--info);color:#fff}
.btn-sm{padding:6px 14px;font-size:11px}
.btn-xs{padding:4px 10px;font-size:10px}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;font-size:10px;color:var(--text-muted);text-transform:uppercase;padding:8px;border-bottom:1px solid var(--card-border)}
td{padding:8px;border-bottom:1px solid rgba(255,255,255,0.03)}
.badge{display:inline-block;padding:3px 10px;border-radius:50px;font-size:10px;font-weight:600}
.badge-pending{background:rgba(243,156,18,0.15);color:#f39c12}
.badge-awaiting{background:rgba(212,168,67,0.15);color:var(--gold)}
.badge-confirmed{background:rgba(39,174,96,0.15);color:var(--success)}
.badge-shipped{background:rgba(52,152,219,0.15);color:var(--info)}
.badge-delivered{background:rgba(39,174,96,0.2);color:var(--success)}
.badge-cancelled{background:rgba(231,76,60,0.15);color:var(--danger)}
.prod-card{display:flex;gap:12px;padding:12px;border:1px solid var(--card-border);border-radius:8px;margin-bottom:8px;align-items:center}
.prod-card img{width:80px;height:55px;object-fit:cover;border-radius:4px}
.prod-card .info{flex:1}.prod-card .info h4{font-size:14px}.prod-card .info .p{color:var(--gold);font-weight:600}
.toast{position:fixed;bottom:20px;right:20px;background:var(--dark3);border-left:4px solid var(--gold);padding:12px 20px;border-radius:8px;font-size:13px;z-index:9999;animation:fadeIn .3s}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}}
</style></head><body>
<div class="sidebar">
<div class="logo">Lux<span>Auto</span> <small style="display:block;font-size:10px;color:var(--text-muted);font-family:Inter">Admin</small></div>
<div class="nav-item active" onclick="t('dashboard')"><i class="fas fa-chart-pie"></i> Dashboard</div>
<div class="nav-item" onclick="t('products')"><i class="fas fa-car"></i> Products <span class="count" id="pc">0</span></div>
<div class="nav-item" onclick="t('orders')"><i class="fas fa-clipboard-list"></i> Orders <span class="count" id="oc">0</span></div>
<div class="nav-item" onclick="t('settings')"><i class="fas fa-cog"></i> Settings</div>
<div class="nav-item" onclick="t('sync')"><i class="fas fa-sync"></i> Data Sync</div>
<hr style="border-color:var(--card-border);margin:12px 20px">
<a class="nav-item" href="index.html" target="_blank" style="text-decoration:none;display:flex"><i class="fas fa-store"></i> Storefront</a>
<a class="nav-item" href="track.html" target="_blank" style="text-decoration:none;display:flex"><i class="fas fa-truck"></i> Tracking</a>
</div>
<div class="main">
<div class="main-header"><h1><span>Admin</span> Dashboard</h1></div>

<div class="tab active" id="tab-dashboard">
<div class="stats" id="statsRow"></div>
<div class="card"><h3>Recent Orders</h3><div id="recentOrders"></div></div>
</div>

<div class="tab" id="tab-products">
<div class="card"><h3>Add / Edit Product</h3>
<div class="form-row"><label>Product Name</label><input id="pn" placeholder="e.g. Lamborghini Huracán" /></div>
<div class="form-row"><label>Image URL</label><input id="pi" placeholder="https://..." /><div id="imgPrev" style="display:none;margin-top:6px"><img id="preview" style="height:120px;border-radius:6px;object-fit:cover" /></div></div>
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
<div class="form-row"><label>Price USD</label><input id="pp" type="number" placeholder="289000" /></div>
<div class="form-row"><label>Year</label><input id="pm" placeholder="2026" /></div>
<div class="form-row"><label>Mileage</label><input id="pmi" placeholder="0 mi" /></div></div>
<div class="form-row"><label>Fuel</label><input id="pf" placeholder="Gasoline" /></div>
<div class="form-row"><label>Description</label><textarea id="pd" rows="2" placeholder="V10, 631 hp..."></textarea></div>
<input type="hidden" id="eid" />
<div style="display:flex;gap:8px"><button class="btn btn-gold" onclick="sp()"><i class="fas fa-save"></i> <span id="sbtn">Add Product</span></button><button class="btn btn-sm" onclick="rpf()" id="cbtn" style="display:none;background:rgba(255,255,255,0.1);color:var(--text)">Cancel</button></div>
</div>
<div class="card"><h3>All Products</h3><div id="prodList"></div></div>
</div>

<div class="tab" id="tab-orders">
<div class="card"><h3>All Orders</h3><div id="ordersList"></div></div>
</div>

<div class="tab" id="tab-settings">
<div class="card"><h3><i class="fas fa-bullhorn"></i> Announcement</h3>
<div class="form-row"><input id="sa" placeholder="FREE DELIVERY on all orders over $50,000" /></div></div>
<div class="card"><h3><i class="fas fa-wallet"></i> Crypto Wallet</h3>
<div class="form-row"><label>Wallet Address</label><input id="sw" placeholder="bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh" /></div>
<div class="form-row"><label>QR Image URL (optional)</label><input id="sq" placeholder="https://..." /></div></div>
<div class="card"><h3><i class="fas fa-address-card"></i> Contact Info</h3>
<div class="form-row"><label>Email</label><input id="se" placeholder="support@luxauto.com" /></div>
<div class="form-row"><label>Phone</label><input id="sph" placeholder="+1 (800) 555-LUXA" /></div>
<div class="form-row"><label>Address</label><input id="sa2" placeholder="742 Automotive Blvd, Los Angeles, CA" /></div></div>
<button class="btn btn-gold" onclick="saveSettings()"><i class="fas fa-save"></i> Save All Settings</button>
</div>

<div class="tab" id="tab-sync">
<div class="card"><h3><i class="fas fa-database"></i> Data Sync</h3>
<p style="font-size:13px;color:var(--text-muted);margin-bottom:12px">
If admin shows no data, open <b>index.html</b>, press F12 → Console, paste this, then paste the result below:</p>
<pre style="background:var(--dark3);padding:10px;border-radius:6px;font-size:11px;color:var(--gold)">JSON.stringify({products:JSON.parse(localStorage.getItem('luxauto_products')||'[]'),orders:JSON.parse(localStorage.getItem('luxauto_orders')||'[]'),settings:JSON.parse(localStorage.getItem('luxauto_settings')||'{}')})</pre>
<textarea id="importArea" style="width:100%;height:80px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);padding:10px;border-radius:6px;color:var(--text);font-size:12px;font-family:monospace;margin:10px 0" placeholder="Paste exported JSON here..."></textarea>
<div style="display:flex;gap:8px">
<button class="btn btn-info" onclick="importData()"><i class="fas fa-upload"></i> Import</button>
<button class="btn btn-outline" onclick="exportData()" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:var(--text)"><i class="fas fa-download"></i> Export</button>
<button class="btn btn-outline" onclick="loadBridge()" style="background:transparent;border:1px solid rgba(255,255,255,0.15);color:var(--text)"><i class="fas fa-link"></i> Load Bridge</button>
</div>
<div id="bridgeStatus" style="margin-top:8px;font-size:12px;color:var(--text-muted)"></div>
<textarea id="exportArea" style="width:100%;height:80px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);padding:10px;border-radius:6px;color:var(--text);font-size:12px;font-family:monospace;margin:10px 0;display:none" readonly></textarea>
</div></div>
</div>
<script>
// ===== DATA LAYER =====
var K={products:'luxauto_products',orders:'luxauto_orders',settings:'luxauto_settings'};
var DP=[{id:'p1',name:'Lamborghini Huracán EVO',model:'2026',mileage:'0 mi',fuel:'Gasoline',image:'https://images.unsplash.com/photo-1544636331-e26879cd4d9b?w=800&q=80',price:289000,description:'V10 engine, 631 hp, 0-60 in 2.9s'},{id:'p2',name:'Porsche 911 Turbo S',model:'2025',mileage:'120 mi',fuel:'Gasoline',image:'https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=800&q=80',price:207000,description:'Twin-turbo flat-6, 640 hp, AWD'},{id:'p3',name:'Mercedes-AMG GT 63 S',model:'2026',mileage:'50 mi',fuel:'Gasoline',image:'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?w=800&q=80',price:185000,description:'V8 biturbo, 630 hp, 4MATIC+'},{id:'p4',name:'Rolls-Royce Ghost',model:'2025',mileage:'200 mi',fuel:'Gasoline',image:'https://images.unsplash.com/photo-1631295868223-63265b40d9e4?w=800&q=80',price:365000,description:'V12 engine, 563 hp, Bespoke luxury'}];
var DS={announcement:'🏆 FREE DELIVERY on all orders over $50,000',walletAddress:'bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh',qrImage:'',email:'support@luxauto.com',phone:'+1 (800) 555-LUXA',address:'742 Automotive Blvd, Suite 200, Los Angeles, CA 90017'};
function g(k){try{var r=localStorage.getItem(k);if(r===null){if(k===K.products){s(K.products,DP);return JSON.parse(JSON.stringify(DP))}if(k===K.settings){s(K.settings,DS);return JSON.parse(JSON.stringify(DS))}return k===K.orders?[]:{}}return JSON.parse(r)}catch(e){return k===K.products?JSON.parse(JSON.stringify(DP)):[]}}
function s(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch(e){}}
function gp(){return g(K.products)}
function go(){return g(K.orders)}
function gs(){return g(K.settings)}
function spr(p){s(K.products,p)}
function sor(o){s(K.orders,o)}
function sst(s){s(K.settings,s)}

// ===== TOAST =====
function t2(m,t){t=t||'info';var d=document.createElement('div');d.className='toast';d.style.borderLeftColor=t==='success'?'var(--success)':t==='error'?'var(--danger)':'var(--gold)';d.innerHTML=m;document.body.appendChild(d);setTimeout(function(){d.remove()},2500)}

// ===== TABS =====
function t(name){document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('active')});var e=document.getElementById('tab-'+name);if(e)e.classList.add('active');document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active')});document.querySelectorAll('.nav-item').forEach(function(n){if(n.textContent.trim().toLowerCase().indexOf(name)!==-1)n.classList.add('active')});if(name==='dashboard')rd();if(name==='products')rp2();if(name==='orders')ro();if(name==='settings')lsf()}

// ===== DASHBOARD =====
function rd(){var p=gp(),o=go();var st='<div class="stat-card"><div class="n">'+p.length+'</div><div class="l">Products</div></div><div class="stat-card"><div class="n">'+o.length+'</div><div class="l">Orders</div></div>';var pend=0;for(var i=0;i<o.length;i++){if(o[i].status==='pending'||o[i].status==='awaiting_confirmation')pend++}st+='<div class="stat-card"><div class="n">'+pend+'</div><div class="l">Pending</div></div>';var rev=0;for(var i=0;i<o.length;i++){if(o[i].status!=='cancelled')rev+=(o[i].total||0)}st+='<div class="stat-card"><div class="n">$'+(rev/1000).toFixed(1)+'k</div><div class="l">Revenue</div></div>';var cs=new Set();for(var i=0;i<o.length;i++){if(o[i].customer&&o[i].customer.email)cs.add(o[i].customer.email)}st+='<div class="stat-card"><div class="n">'+cs.size+'</div><div class="l">Customers</div></div>';document.getElementById('statsRow').innerHTML=st;var r=[];for(var i=o.length-1;i>=0&&r.length<5;i--)r.push(o[i]);var c=document.getElementById('recentOrders');if(r.length===0){c.innerHTML='<p style="color:var(--text-muted)">No orders yet.</p>';uc();return}var h='<table><tr><th>Tracking</th><th>Customer</th><th>Total</th><th>Status</th><th>Date</th></tr>';for(var i=0;i<r.length;i++){var o2=r[i];h+='<tr><td style="font-family:monospace;font-size:11px;color:var(--gold)">'+(o2.trackingNumber||'N/A')+'</td><td>'+(o2.customer?o2.customer.name:'-')+'</td><td>$'+((o2.total||0).toLocaleString())+'</td><td><span class="badge badge-'+o2.status+'">'+(o2.status||'')+'</span></td><td>'+(o2.createdAt?new Date(o2.createdAt).toLocaleDateString():'-')+'</td></tr>'}h+='</table>';c.innerHTML=h;uc()}
function uc(){document.getElementById('pc').textContent=gp().length;document.getElementById('oc').textContent=go().length}

// ===== FEATURE 4: PRODUCTS (image URL + price) =====
document.getElementById('pi').addEventListener('input',function(){var u=this.value.trim();var p=document.getElementById('imgPrev');if(u){p.style.display='block';document.getElementById('preview').src=u}else{p.style.display='none'}})
function rpf(){document.getElementById('pn').value='';document.getElementById('pi').value='';document.getElementById('imgPrev').style.display='none';document.getElementById('pp').value='';document.getElementById('pm').value='';document.getElementById('pmi').value='';document.getElementById('pf').value='';document.getElementById('pd').value='';document.getElementById('eid').value='';document.getElementById('sbtn').textContent='Add Product';document.getElementById('cbtn').style.display='none'}
function sp(){var n=document.getElementById('pn').value.trim(),im=document.getElementById('pi').value.trim(),pr=parseFloat(document.getElementById('pp').value);if(!n||!im||!pr){t2('Name, Image URL, Price required','error');return}var mo=document.getElementById('pm').value.trim(),mi=document.getElementById('pmi').value.trim(),f=document.getElementById('pf').value.trim(),d=document.getElementById('pd').value.trim(),eid=document.getElementById('eid').value;var pts=gp();if(eid){for(var i=0;i<pts.length;i++){if(pts[i].id===eid){pts[i]={id:eid,name:n,image:im,price:pr,model:mo||pts[i].model,mileage:mi||pts[i].mileage,fuel:f||pts[i].fuel,description:d||pts[i].description};break}}t2('Product updated!','success')}else{pts.push({id:'p'+Date.now()+Math.random().toString(36).substring(2,6),name:n,image:im,price:pr,model:mo||'',mileage:mi||'',fuel:f||'',description:d||''});t2('Product added!','success')}spr(pts);rpf();rp2();uc()}
function ep(id){var pts=gp(),p=null;for(var i=0;i<pts.length;i++){if(pts[i].id===id){p=pts[i];break}}if(!p)return;document.getElementById('pn').value=p.name;document.getElementById('pi').value=p.image;document.getElementById('imgPrev').style.display='block';document.getElementById('preview').src=p.image;document.getElementById('pp').value=p.price;document.getElementById('pm').value=p.model||'';document.getElementById('pmi').value=p.mileage||'';document.getElementById('pf').value=p.fuel||'';document.getElementById('pd').value=p.description||'';document.getElementById('eid').value=id;document.getElementById('sbtn').textContent='Update';document.getElementById('cbtn').style.display='inline-flex'}
function dp(id){if(!confirm('Delete?'))return;var pts=[];var old=gp();for(var i=0;i<old.length;i++){if(old[i].id!==id)pts.push(old[i])}spr(pts);rp2();uc();t2('Deleted','info')}
function rp2(){var pts=gp();var c=document.getElementById('prodList');if(pts.length===0){c.innerHTML='<p style="color:var(--text-muted)">No products.</p>';return}var h='';for(var i=0;i<pts.length;i++){var p=pts[i];h+='<div class="prod-card"><img src="'+p.image+'" onerror="this.src=\'https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=200&q=60\'" /><div class="info"><h4>'+p.name+'</h4><div class="p">$'+p.price.toLocaleString()+'</div><div style="font-size:11px;color:var(--text-muted)">'+(p.model||'')+' | '+(p.mileage||'')+'</div></div><div><button class="btn btn-sm" onclick="ep(\''+p.id+'\')" style="background:rgba(255,255,255,0.06);color:var(--text)"><i class="fas fa-edit"></i></button><button class="btn btn-danger btn-sm" onclick="dp(\''+p.id+'\')"><i class="fas fa-trash"></i></button></div></div>'}c.innerHTML=h}

// ===== FEATURES 1,2,3: ORDERS =====
function ro(){var o=go();var c=document.getElementById('ordersList');if(o.length===0){c.innerHTML='<p style="color:var(--text-muted)">No orders yet. Make a purchase on index.html first.</p>';return}var s=[];for(var i=o.length-1;i>=0;i--)s.push(o[i]);var h='<table><tr><th>Tracking</th><th>Customer</th><th>Total</th><th>Payment</th><th>Status</th><th>Actions</th></tr>';for(var i=0;i<s.length;i++){var o2=s[i];h+='<tr><td style="font-family:monospace;font-size:11px;color:var(--gold)">'+(o2.trackingNumber||'N/A')+'</td><td>'+(o2.customer?o2.customer.name:'-')+'<br><span style="font-size:10px;color:var(--text-muted)">'+(o2.customer?o2.customer.email:'')+'</span></td><td>$'+((o2.total||0).toLocaleString())+'</td><td style="font-size:11px">'+(o2.paymentMethod||'')+'</td><td><span class="badge badge-'+o2.status+'">'+(o2.status||'')+'</span></td><td>';if(o2.status==='pending'||o2.status==='awaiting_confirmation')h+='<button class="btn btn-success btn-xs" onclick="cp(\''+o2.id+'\')"><i class="fas fa-check"></i> Confirm Pay</button> ';if(o2.status==='confirmed')h+='<button class="btn btn-info btn-xs" onclick="us(\''+o2.id+'\')"><i class="fas fa-truck"></i> Ship</button> ';if(o2.status==='shipped'){h+='<button class="btn btn-info btn-xs" onclick="usi(\''+o2.id+'\')"><i class="fas fa-edit"></i> Update</button> ';h+='<button class="btn btn-success btn-xs" onclick="md(\''+o2.id+'\')"><i class="fas fa-home"></i> Deliver</button> '}if(o2.status!=='cancelled'&&o2.status!=='delivered')h+='<button class="btn btn-danger btn-xs" onclick="co(\''+o2.id+'\')"><i class="fas fa-times"></i> Cancel</button> ';h+='<button class="btn btn-xs" onclick="vo(\''+o2.id+'\')" style="background:rgba(255,255,255,0.05);color:var(--text-muted)"><i class="fas fa-eye"></i></button>';h+='</td></tr>'}h+='</table>';c.innerHTML=h}
function cp(id){if(!confirm('Confirm payment?'))return;var o=go();for(var i=0;i<o.length;i++){if(o[i].id===id){o[i].status='confirmed';o[i].paymentStatus='paid';break}}sor(o);ro();rd();t2('Payment confirmed!','success')}
function us(id){var info=prompt('Enter shipping tracking info:');if(info===null||!info.trim())return;var o=go();for(var i=0;i<o.length;i++){if(o[i].id===id){o[i].status='shipped';o[i].shippingInfo=info.trim();o[i].shippedDate=new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});break}}sor(o);ro();rd();t2('Order shipped!','success')}
function usi(id){var info=prompt('Update shipping info:');if(info===null||!info.trim())return;var o=go();for(var i=0;i<o.length;i++){if(o[i].id===id){o[i].shippingInfo=info.trim();break}}sor(o);ro();t2('Shipping updated!','success')}
function md(id){if(!confirm('Mark delivered?'))return;var o=go();for(var i=0;i<o.length;i++){if(o[i].id===id){o[i].status='delivered';o[i].deliveryDate=new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});break}}sor(o);ro();rd();t2('Delivered!','success')}
function co(id){if(!confirm('CANCEL this order? Cannot undo.'))return;var o=go();for(var i=0;i<o.length;i++){if(o[i].id===id){o[i].status='cancelled';break}}sor(o);ro();rd();t2('Cancelled','info')}
function vo(id){var o=go(),f=null;for(var i=0;i<o.length;i++){if(o[i].id===id){f=o[i];break}}if(!f){t2('Not found','error');return}var is='';var its=f.items||[];for(var i=0;i<its.length;i++){is+='• '+its[i].name+' x'+(its[i].qty||1)+' = $'+((its[i].price||0)*(its[i].qty||1)).toLocaleString()+'\n'}alert('=== ORDER ===\nTracking: '+(f.trackingNumber||'N/A')+'\nStatus: '+(f.status||'')+'\nPayment: '+(f.paymentMethod||'')+'\n\nCustomer: '+(f.customer?f.customer.name:'')+'\n'+(f.customer?f.customer.email:'')+'\n'+(f.customer?f.customer.phone:'')+'\n'+(f.customer?f.customer.address:'')+', '+(f.customer?f.customer.country:'')+'\n\nItems:\n'+(is||'None')+'\nTotal: $'+((f.total||0).toLocaleString())+'\n\nShipping: '+(f.shippingInfo||'Pending')+'\nDelivered: '+(f.deliveryDate||'Pending'))}

// ===== FEATURE 5: SETTINGS =====
function lsf(){var s=gs();document.getElementById('sa').value=s.announcement||'';document.getElementById('sw').value=s.walletAddress||'';document.getElementById('sq').value=s.qrImage||'';document.getElementById('se').value=s.email||'';document.getElementById('sph').value=s.phone||'';document.getElementById('sa2').value=s.address||''}
function saveSettings(){var s={announcement:document.getElementById('sa').value.trim()||DS.announcement,walletAddress:document.getElementById('sw').value.trim()||DS.walletAddress,qrImage:document.getElementById('sq').value.trim()||'',email:document.getElementById('se').value.trim()||DS.email,phone:document.getElementById('sph').value.trim()||DS.phone,address:document.getElementById('sa2').value.trim()||DS.address};sst(s);t2('All settings saved!','success')}

// ===== DATA SYNC =====
function importData(){var t=document.getElementById('importArea').value.trim();if(!t){t2('Paste data first','error');return}try{var d=JSON.parse(t);var c=0;if(d.products&&Array.isArray(d.products)){spr(d.products);c++}if(d.orders&&Array.isArray(d.orders)){sor(d.orders);c++}if(d.settings&&typeof d.settings==='object'){sst(d.settings);c++}t2('Imported '+c+' datasets!','success');rd();rp2();lsf();document.getElementById('importArea').value=''}catch(e){t2('Invalid JSON: '+e.message,'error')}}
function exportData(){var d={products:gp(),orders:go(),settings:gs()};var ta=document.getElementById('exportArea');ta.value=JSON.stringify(d,null,2);ta.style.display='block';ta.select();t2('Copy this JSON to import into index.html','info')}
function loadBridge(){if(!window.name||window.name.indexOf('LUXAUTO|')!==0){document.getElementById('bridgeStatus').innerHTML='<span style="color:var(--warning)">No bridge data. Navigate from index.html in same tab.</span>';return}try{var raw=window.name.substring('LUXAUTO|'.length);var d=JSON.parse(decodeURIComponent(escape(atob(raw))));var c=0;if(d.orders&&d.orders.length>0){sor(d.orders);c++}if(d.products&&d.products.length>0){spr(d.products);c++}if(d.settings){sst(d.settings);c++}document.getElementById('bridgeStatus').innerHTML='<span style="color:var(--success)">✅ Loaded '+c+' datasets from bridge!</span>';rd();rp2();lsf();t2('Bridge data loaded!','success')}catch(e){document.getElementById('bridgeStatus').innerHTML='<span style="color:var(--danger)">Error: '+e.message+'</span>'}}
// Auto-load bridge
try{if(window.name&&window.name.indexOf('LUXAUTO|')===0){var raw=window.name.substring('LUXAUTO|'.length);var d=JSON.parse(decodeURIComponent(escape(atob(raw))));if(d.orders&&d.orders.length>0)sor(d.orders);if(d.products&&d.products.length>0)spr(d.products);if(d.settings)sst(d.settings)}}catch(e){}

// ===== INIT =====
rd();
</script></body></html>
